# ── Dad Bod Checker environment ──────────────────────────────────────────────
# Copy this file to `.env.local` and fill in values to enable the live Vision AI.

# Anthropic API key used for the live Vision AI analysis.
# Leave blank to run in DEMO MODE — a deterministic mock rating is returned so the
# app works fully offline with no key.
ANTHROPIC_API_KEY=

# Anthropic model used to analyze the photo and write the review.
VISION_MODEL=claude-sonnet-4-6

# Public base URL of the deployed site. Used for Open Graph / share metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
